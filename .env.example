PORT=8787

APP_USERNAME=admin
APP_PASSWORD=change-this-password
SESSION_SECRET=replace-with-at-least-32-random-characters

REMNAWAVE_BASE_URL=https://panel.example.com
REMNAWAVE_API_TOKEN=replace-with-remnawave-api-token

REFRESH_INTERVAL_SECONDS=30

DB_PATH=./data/remnawave-monitor.sqlite
SYNC_INTERVAL_SECONDS=60
IP_HISTORY_RETENTION_HOURS=24
IP_STABILITY_WINDOW_MINUTES=15
SYNC_LOG_RETENTION_DAYS=7
HWID_DETAILS_LIMIT=150
HWID_DETAILS_CONCURRENCY=8
IP_GEO_ENABLED=true
IP_GEO_CACHE_TTL_DAYS=7
IP_GEO_SYNC_LIMIT=200
IP_GEO_CONCURRENCY=4

# Retention Policy (days)
HWID_HISTORY_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=14
ACTIVITY_HISTORY_RETENTION_DAYS=7

# Session
SESSION_MAX_AGE_SECONDS=43200

# Telegram Bot Token (для отправки предупреждений пользователям)
TELEGRAM_BOT_TOKEN=

# AI analysis (optional)
AI_ENABLED=false
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=900
AI_TIMEOUT_SECONDS=30
